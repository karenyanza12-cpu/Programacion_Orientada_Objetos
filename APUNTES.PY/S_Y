def suma(a, b):
    return a+b
 
def resta(a, b):
    return a-b
 
def multiplicacion(a, b):
    return a*b
 
def division(a, b):
    if b == 0:
        return "error, no se puede dividir para 0"
    return a/b
 
def calculadora():
    while True:
        print("Bienvenidos a la calculadora rapida")
        print("----------Menu de Opciones")
        print("1. Suma")
        print("2. Resta")
        print("3. Multiplicacion")
        print("4. Division")
        print("5. Salir")
        op = int(input("Escriba el numero de la opcion: "))
 
        if op == 5:
            print("Gracias por usar la calculadora")
            break
        num1 = int(input("Ingrese el primero numero: "))
        num2 = int(input("Ingrese el segundo numero: "))
 
        if op==1:
            print("Resultado Suma: ", suma(num1, num2))
        elif op==2:
            print("Resultado Resta: ", resta(num1, num2))
        elif op==3:
            print("Resultado Multiplicacion: ", multiplicacion(num1, num2))
        elif op==4:
            print("Resultado Divisions: ", division(num1, num2))
        else:
            print("Opcion no valida")
    
calculadora()
